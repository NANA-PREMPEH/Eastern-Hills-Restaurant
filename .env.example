# Optional: client-side PIN used for the hidden staff login UI.
# If you set this, use the same value for ADMIN_PIN on the server.
VITE_ADMIN_PIN="1234"

# Recommended: server-side PIN used to protect menu write APIs.
# Set this in Vercel Project Settings -> Environment Variables.
ADMIN_PIN="1234"

# Required for the shared menu database on Vercel.
# Use a Postgres integration such as Neon from the Vercel Marketplace.
DATABASE_URL="postgresql://user:password@host/database?sslmode=require"
# Alternate Postgres variable supported by this app and commonly injected by Vercel integrations.
POSTGRES_URL="postgresql://user:password@host/database?sslmode=require"

# Required for uploaded dish images on Vercel Blob.
# This is injected automatically when you connect a Blob store to the project.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxx"

# Also injected automatically by the Vercel Blob integration.
# These are not required by the current server-upload flow, but can remain configured.
BLOB_STORE_ID="store_xxxxx"
BLOB_WEBHOOK_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"
